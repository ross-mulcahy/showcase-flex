{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "showcase-flex/video-background",
	"version": "1.0.0",
	"title": "Video Background Section",
	"category": "showcase-flex",
	"icon": "video-alt3",
	"description": "Section with muted autoplaying background video and text overlay.",
	"keywords": ["video", "background", "media", "cinematic"],
	"textdomain": "showcase-flex",
	"editorScript": "showcase-flex-editor",
	"attributes": {
		"videoUrl": { "type": "string", "default": "" },
		"posterUrl": { "type": "string", "default": "" },
		"title": { "type": "string", "default": "" },
		"text": { "type": "string", "default": "" }
	},
	"supports": { "html": false, "align": ["full"] },
	"render": "file:./render.php"
}
