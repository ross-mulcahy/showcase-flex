{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "showcase-flex/parallax-hero",
	"version": "1.0.0",
	"title": "Parallax Hero",
	"category": "showcase-flex",
	"icon": "format-image",
	"description": "Full-bleed parallax hero with Ken Burns zoom, headline, subtitle, and byline.",
	"keywords": ["hero", "parallax", "banner", "header"],
	"textdomain": "showcase-flex",
	"attributes": {
		"imageUrl": { "type": "string", "default": "" },
		"kicker": { "type": "string", "default": "Investigation" },
		"title": { "type": "string", "default": "The Deep Current" },
		"subtitle": { "type": "string", "default": "" },
		"byline": { "type": "string", "default": "" },
		"dateline": { "type": "string", "default": "" }
	},
	"supports": {
		"html": false,
		"align": ["full"],
		"color": { "background": false, "text": false }
	},
	"render": "file:./render.php"
}
