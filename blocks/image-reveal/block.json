{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "showcase-flex/image-reveal",
	"version": "1.0.0",
	"title": "Image Reveal",
	"category": "showcase-flex",
	"icon": "visibility",
	"description": "Image that unveils with a clip-path wipe and blur-to-sharp transition on scroll.",
	"keywords": ["image", "reveal", "animation", "scroll"],
	"textdomain": "showcase-flex",
	"attributes": {
		"imageUrl": { "type": "string", "default": "" },
		"alt": { "type": "string", "default": "" },
		"credit": { "type": "string", "default": "" },
		"caption": { "type": "string", "default": "" }
	},
	"supports": { "html": false, "align": ["wide", "full"] },
	"render": "file:./render.php"
}
